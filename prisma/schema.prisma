// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 小说项目
model Project {
  id            String         @id @default(cuid())
  title         String
  description   String?
  genre         String         // 小说类型
  tags          String?        // JSON数组字符串
  status        String         @default("draft") // draft, writing, completed
  coverImage    String?

  // 统计信息
  totalWords    Int            @default(0)
  chapterCount  Int            @default(0)

  // 大纲模式
  outlineMode   String         @default("full") // full, progressive
  planningRange Int?           @default(10)     // 渐进式规划时的章节范围

  // 关联数据
  outlines      Outline[]
  chapters      Chapter[]
  characters    Character[]
  worldElements WorldElement[]
  generations   Generation[]
  foreshadowings Foreshadowing[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([genre])
}

// 大纲节点
model Outline {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      String    // volume, chapter, scene
  order     Int       // 排序
  title     String
  description String?
  targetWords Int?

  // 渐进式规划
  planningMode String   @default("full") // full, progressive
  planningRange Int?                     // 规划范围
  isFlexible   Boolean  @default(false)  // 是否允许灵活调整
  confidence   Int      @default(5)      // 规划置信度(1-10)

  // 结构化创作意图
  emotionalGoal String?                  // 情感目标：此章节想传达的情感
  plotFunction  String   @default("推进") // 情节功能：推进/转折/铺垫/高潮/过渡
  tensionLevel  Int      @default(5)      // 张力等级 1-10

  // 树形结构
  parentId  String?
  parent    Outline?  @relation("OutlineHierarchy", fields: [parentId], references: [id])
  children  Outline[] @relation("OutlineHierarchy")

  // 关联章节
  chapterId String?  @unique
  chapter   Chapter?  @relation(fields: [chapterId], references: [id])

  status    String    @default("planned") // planned, writing, completed

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([parentId])
}

// 章节
model Chapter {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  chapterNumber  Int
  title          String
  content        String    // Markdown格式

  // 统计
  wordCount      Int       @default(0)

  // 元数据
  summary        String?   // 章节摘要(用于上下文)
  notes          String?   // 作者笔记
  isKeyChapter   Boolean   @default(false) // 是否为关键章节
  plotType       String?   // 情节类型: setup, conflict, climax, resolution

  // 关联
  outline        Outline?
  scenes         Scene[]
  plantedForeshadowings   Foreshadowing[] @relation("PlantedForeshadowing")
  resolvedForeshadowings  Foreshadowing[] @relation("ResolvedForeshadowing")
  characterSnapshots      CharacterSnapshot[]
  worldElementSnapshots   WorldElementSnapshot[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([projectId, chapterNumber])
  @@index([projectId])
}

// 场景(章节内的细分)
model Scene {
  id          String    @id @default(cuid())
  chapterId   String
  chapter     Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  order       Int
  title       String?
  content     String
  characters  String?   // JSON数组 - 出场角色ID
  location    String?   // 场景地点

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([chapterId])
}

// 角色
model Character {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name           String
  nickname       String?
  age            Int?
  gender         String?

  // 角色重要性
  importance     Int       @default(5)      // 1-10，影响上下文权重
  role           String    @default("supporting") // protagonist, antagonist, supporting, minor

  // 外貌描述
  appearance     String?

  // 性格特点
  personality    String?
  backstory      String?
  motivation     String?   // 角色动机

  // 对话风格示例
  dialogueStyle  String?

  // 关系图谱 (JSON字符串)
  relationships  String?   // { characterId: { relation: string, description: string } }

  // 角色弧光
  characterArc   String?

  // 头像
  avatar         String?

  // 关联
  snapshots      CharacterSnapshot[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([projectId])
}

// 世界观元素
model WorldElement {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type        String    // location, history, magic, organization, item, other
  name        String
  description String

  // 动态属性 (JSON字符串)
  attributes  String?

  // 分层管理
  importance  Int       @default(5)      // 重要性 1-10，影响上下文权重
  scope       String    @default("local") // global(全局), regional(区域), local(局部)
  category    String    @default("detail") // core_rule(核心规则), detail(细节), background(背景)
  isEvolvable Boolean   @default(false)  // 是否可演化（如势力、角色状态等）

  // 层级关系（支持世界观元素的树形结构）
  parentId    String?
  parent      WorldElement?  @relation("WorldHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    WorldElement[] @relation("WorldHierarchy")

  // 约束和规则
  constraints String?   // JSON字符串 - 设定的约束条件
  exceptions  String?   // JSON字符串 - 例外情况
  evolutionSpace String? // 演化空间描述

  // 关联 (JSON字符串)
  relatedTo   String?   // [{ elementId, relationType }]

  // 引用 (JSON字符串)
  references  String?   // [{ chapterId, context }]

  // 使用统计
  usageCount  Int       @default(0)      // 被引用次数
  lastUsedAt  DateTime?                  // 最后使用时间

  // 关联快照
  snapshots   WorldElementSnapshot[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([importance])
  @@index([scope])
  @@index([category])
  @@index([parentId])
}

// AI生成记录(用于成本控制和历史追溯)
model Generation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type      String   // chapter, outline, character, dialogue, world
  targetId  String?  // 生成目标的ID

  // AI配置
  provider  String   // google, openai, claude
  model     String   // gemini-2.5-flash, gemini-2.5-pro, etc.

  // 提示词
  prompt    String
  systemPrompt String?

  // 结果
  output    String
  tokensUsed String?  // JSON字符串 - { promptTokens, completionTokens, totalTokens }
  cost      Float?

  // 时间
  duration  Int?     // 毫秒
  status    String   // success, error, partial

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([type])
  @@index([createdAt])
}

// 伏笔管理
model Foreshadowing {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String
  type        String   // plot, character, world, mystery
  importance  Int      @default(5) // 1-10

  // 埋设信息
  plantedInChapterId   String?
  plantedInChapter     Chapter? @relation("PlantedForeshadowing", fields: [plantedInChapterId], references: [id], onDelete: SetNull)
  plantedContent       String?
  plantedAt            DateTime?

  // 回收信息
  expectedChapterNumber Int?
  resolvedInChapterId   String?
  resolvedInChapter     Chapter? @relation("ResolvedForeshadowing", fields: [resolvedInChapterId], references: [id], onDelete: SetNull)
  resolvedContent       String?
  resolvedAt            DateTime?

  // 状态和关联
  status      String   @default("planned") // planned, planted, resolved, abandoned
  relatedCharacters String? // JSON数组 - 相关角色ID
  relatedElements   String? // JSON数组 - 相关世界观元素ID
  tags              String? // JSON数组 - 标签
  reminderChapterNumber Int? // 提醒章节号

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([plantedInChapterId])
  @@index([resolvedInChapterId])
}

// 角色快照
model CharacterSnapshot {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  chapterId     String?
  chapter       Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  chapterNumber Int

  // 快照数据
  age         Int?
  appearance  String?
  personality String?
  powerLevel  String?
  skills      String?   // JSON数组
  items       String?   // JSON数组
  status      String?   // 状态描述
  relationships String? // JSON对象 - 关系变化
  mentalState String?   // 心理状态
  motivation  String?   // 当前动机
  majorEvents String?   // 重大事件记录
  notes       String?   // 备注

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([characterId])
  @@index([chapterId])
  @@index([chapterNumber])
  @@unique([characterId, chapterNumber])
}

// 世界观元素快照
model WorldElementSnapshot {
  id          String       @id @default(cuid())
  elementId   String
  element     WorldElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  chapterId     String?
  chapter       Chapter?   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  chapterNumber Int

  // 快照数据
  description   String     // 当时的描述
  attributes    String?    // 当时的属性（JSON）
  constraints   String?    // 当时的约束条件
  changeReason  String?    // 变化原因
  changeType    String?    // 变化类型：expansion(扩展), modification(修改), evolution(演化)

  // 影响范围
  affectedCharacters String? // JSON数组 - 受影响的角色ID
  affectedPlots      String? // 对情节的影响描述

  notes         String?    // 备注

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([elementId])
  @@index([chapterId])
  @@index([chapterNumber])
  @@unique([elementId, chapterNumber])
}

// 系统配置
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String   // ai, export, editor, etc.

  updatedAt   DateTime @updatedAt

  @@index([category])
}
